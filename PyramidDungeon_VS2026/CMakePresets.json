{
  "version": 6,
  "configurePresets": [
    {
      "name": "vs2026-release",
      "displayName": "Visual Studio 2026 Release x64",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build-vs2026",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_POLICY_VERSION_MINIMUM": "3.10"
      }
    },
    {
      "name": "ninja-msvc-release",
      "displayName": "Ninja + MSVC Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.10"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-vs2026-release",
      "configurePreset": "vs2026-release",
      "configuration": "Release"
    },
    {
      "name": "build-ninja-msvc-release",
      "configurePreset": "ninja-msvc-release"
    }
  ]
}
